{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node@3",
      "config": {
        "includeFiles": ["uploads/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 30
    }
  }
}
